graph TD
    MAIN["main.cpp &rarr; Application &rarr; MainWindow"]

    subgraph APP["gecko_app — Qt UI layer"]
        direction TB
        UI["ui/ — MainWindow, EditorWidget,<br/>panels · dialogs · widgets · theme"]
        REND["ui/rendering — RenderingEngine,<br/>HexRenderer, MapSpriteLoader (SFML)"]
        INPUT["ui/input — InputHandler<br/>(EditorMode dispatch)"]
        TOOLS["ui/tiles · tools · editing —<br/>TilePlacementManager,<br/>ExitGridPlacementManager,<br/>ObjectCommandController + UndoStack"]
        STATE["state/ — MapLoader,<br/>DataPathLoader, GameLauncher"]
        APPUTIL["util/ (Qt) — QtDialogs, Settings,<br/>SpriteFactory, ResourceInitializer"]
    end

    subgraph CORE["gecko_core — Qt-free editor model"]
        direction TB
        EDITOR["editor/ — Object, HexagonGrid,<br/>Hex, ObjectQueries"]
        SEL["selection/ — SelectionManager,<br/>SelectionState"]
        VIEWPORT["ViewportController<br/>(world&harr;hex/tile math, cull)"]
        COREUTIL["util/ — Coordinates,<br/>SpatialIndex, ProHelper"]
    end

    subgraph RES["gecko_resource — Qt-free resources"]
        direction TB
        GAMERES["GameResources (facade)"]
        REPO["ResourceRepository (typed cache)"]
        FRM["FrmResolver (FID &harr; art path)"]
        TEX["TextureManager (FRM&rarr;SFML sheets)"]
        DFS["DataFileSystem"]
        VFS["vfs/ — Dat2FileSystem, Dat2File"]
    end

    subgraph VAULT["vault — Qt-free formats & I/O"]
        direction TB
        FORMAT["format/ — Pro, Map, MapObject,<br/>Frm, Lst, Msg, Pal, Dat, Tile"]
        READ["reader/ — MapReader, ProReader, …"]
        WRITE["writer/ — MapWriter, ProWriter"]
    end

    MAIN --> APP
    APP --> CORE
    CORE --> RES
    RES --> VAULT

    APP -.-> QT["Qt6"]
    APP -.-> SFML["SFML 3"]
    RES -.-> SFML
    RES -.-> VFSPP["vfspp"]
    VFS -.-> ZLIB["zlib"]
    VAULT -.-> SPD["spdlog"]

    classDef app fill:#E6F2FF,stroke:#4A90E2,color:#1a1a1a;
    classDef core fill:#E8F5E9,stroke:#43A047,color:#1a1a1a;
    classDef res fill:#FFF3E0,stroke:#F57C00,color:#1a1a1a;
    classDef vault fill:#F3E5F5,stroke:#8E24AA,color:#1a1a1a;
    classDef ext fill:#ECEFF1,stroke:#90A4AE,color:#1a1a1a;
    class UI,REND,INPUT,TOOLS,STATE,APPUTIL app;
    class EDITOR,SEL,VIEWPORT,COREUTIL core;
    class GAMERES,REPO,FRM,TEX,DFS,VFS res;
    class FORMAT,READ,WRITE vault;
    class QT,SFML,VFSPP,ZLIB,SPD ext;
